# LLM
MEDIAGECKUSSY_LLM_PROVIDER=openrouter
MEDIAGECKUSSY_OPENAI_API_KEY=
MEDIAGECKUSSY_OPENAI_MODEL=gpt-4o-mini
MEDIAGECKUSSY_ANTHROPIC_API_KEY=
MEDIAGECKUSSY_ANTHROPIC_MODEL=claude-haiku-3-5
MEDIAGECKUSSY_OPENROUTER_API_KEY=
MEDIAGECKUSSY_OPENROUTER_MODEL=google/gemini-2.5-flash-lite
MEDIAGECKUSSY_ZAI_API_KEY=
MEDIAGECKUSSY_ZAI_MODEL=glm-4.5-flash
MEDIAGECKUSSY_OLLAMA_BASE_URL=http://localhost:11434
MEDIAGECKUSSY_OLLAMA_MODEL=llama3.2

# Image (for Task 3)
MEDIAGECKUSSY_IMAGE_PROVIDER=dalle
MEDIAGECKUSSY_STABILITY_API_KEY=
MEDIAGECKUSSY_REPLICATE_API_KEY=

# Hydration
MEDIAGECKUSSY_HYDRATION_CONCURRENCY=3
MEDIAGECKUSSY_HYDRATION_MIN_CONFIDENCE=0.7
MEDIAGECKUSSY_AUTO_HYDRATE=false

# Studio (for Task 4)
MEDIAGECKUSSY_STUDIO_PORT=4999
MEDIAGECKUSSY_STUDIO_HOST=localhost

# Hosted demo notes
# - keep provider keys on the server only
# - OpenRouter + Gemini 2.5 Flash Lite is the default hosted demo path
# - Z.AI can be enabled as an alternate built-in inference backend
