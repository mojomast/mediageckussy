<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{publicCanon.title}}</title>
    <meta name="description" content="{{publicCanon.logline}}">
    <link rel="stylesheet" href="assets/styles.css">
  </head>
  <body>
    <header class="site-header">
      <a href="index.html" class="wordmark">{{publicCanon.title}}</a>
      <nav>
        <a href="about.html">About</a>
        <a href="story.html">Story</a>
        <a href="characters.html">Characters</a>
        <a href="press.html">Press</a>
        <a href="partners.html">Partners</a>
      </nav>
    </header>
    <main>
      <section class="hero">
        <p class="eyebrow">Feature Film Package</p>
        <h1>{{publicCanon.title}}</h1>
        <p class="lede">{{publicCanon.logline}}</p>
        <p class="meta">{{canon.genre.value}} | {{canon.duration_count.value}}</p>
      </section>
      <section class="panel">
        <h2>Principal Characters</h2>
        <div class="grid">
          {{#each publicCanon.characters}}
          <article class="card">
            <h3>{{name}}</h3>
            <p><strong>{{role}}</strong></p>
            <p>{{description}}</p>
          </article>
          {{/each}}
        </div>
      </section>
    </main>
  </body>
</html>
