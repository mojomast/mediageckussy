{
  "name": "media-package-generator",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "mediageck": "dist/cli/index.js",
    "mpg": "dist/cli/index.js"
  },
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "scripts": {
    "onboard:tv": "tsx src/cli/onboard.ts examples/sample-tv/canon.yaml output/neon-aftercare",
    "onboard:film": "tsx src/cli/onboard.ts examples/sample-film/canon.yaml output/glass-harbor",
    "onboard:podcast": "tsx src/cli/onboard.ts examples/sample-podcast/canon.yaml output/signal-and-bone",
    "onboard:web": "tsx src/cli/onboard.ts examples/sample-web-series/canon.yaml output/soft-launch",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-prompt-assets.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:example": "tsx src/cli/index.ts generate --canon examples/sample-tv/canon.yaml --out output/neon-aftercare",
    "generate:film": "tsx src/cli/index.ts generate --canon examples/sample-film/canon.yaml --out output/glass-harbor",
    "generate:podcast": "tsx src/cli/index.ts generate --canon examples/sample-podcast/canon.yaml --out output/signal-and-bone",
    "generate:web": "tsx src/cli/index.ts generate --canon examples/sample-web-series/canon.yaml --out output/soft-launch",
    "regenerate:website": "tsx src/cli/index.ts regenerate --canon examples/sample-tv/canon.yaml --out output/neon-aftercare --department website",
    "publish:tv": "tsx src/cli/publish-site.ts output/neon-aftercare deploy/neon-aftercare-site",
    "publish:film": "tsx src/cli/publish-site.ts output/glass-harbor deploy/glass-harbor-site",
    "publish:podcast": "tsx src/cli/publish-site.ts output/signal-and-bone deploy/signal-and-bone-site",
    "publish:web": "tsx src/cli/publish-site.ts output/soft-launch deploy/soft-launch-site",
    "test:regions": "vitest run src/utils/protectedRegions.test.ts",
    "studio": "node ./dist/server/index.js",
    "studio:dev": "concurrently \"npx tsx watch src/server/index.ts\" \"vite studio/ --port 5173\"",
    "build:studio": "vite build --config studio/vite.config.ts",
    "check:studio": "tsc -p studio/tsconfig.json --noEmit",
    "hydrate:tv": "tsx src/cli/index.ts hydrate --canon examples/sample-tv/canon.yaml --out output/neon-aftercare --mode bulk",
    "assets:tv": "tsx src/cli/index.ts assets generate --canon examples/sample-tv/canon.yaml --out output/neon-aftercare --all",
    "test:integration": "vitest run --reporter=verbose src/__tests__/**/*.integration.test.ts"
  },
  "keywords": [
    "media",
    "generator",
    "canon",
    "templates",
    "static-site"
  ],
  "author": "",
  "license": "ISC",
  "description": "Canon-first media package generator for TV-first repo-native creative packages.",
  "dependencies": {
    "@inquirer/prompts": "^7.8.6",
    "@anthropic-ai/sdk": "^0.87.0",
    "@monaco-editor/react": "^4.7.0",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "fs-extra": "^11.3.2",
    "handlebars": "^4.7.8",
    "openai": "^6.34.0",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "tar": "^7.5.13",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.10",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.3",
    "vitest": "^4.1.4"
  }
}
